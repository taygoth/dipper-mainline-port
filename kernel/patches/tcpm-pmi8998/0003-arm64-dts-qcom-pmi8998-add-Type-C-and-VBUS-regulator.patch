From 456807e56bfb43f6db35cff7c7e5ce12b2923453 Mon Sep 17 00:00:00 2001
From: Max Furman <taygoth@gmail.com>
Date: Mon, 1 Jun 2026 00:27:19 +0500
Subject: [PATCH 3/4] arm64: dts: qcom: pmi8998: add Type-C and VBUS regulator
 nodes

Add the pmi8998_vbus regulator node at SPMI offset 0x1100 and the
pmi8998_typec node at offset 0x1300, both disabled by default so
existing PMI8998-using boards keep their current behaviour.

The Type-C node carries the type-c-change rollup IRQ (perph 0x13)
plus all seven PDPHY IRQs (perph 0x17 mask 0..6) and lists the
PDPHY register range at 0x1700 as a secondary reg entry.

A board that wires the Type-C controller (sdm845-oneplus-common,
sdm845-xiaomi-dipper, ...) overrides status = "okay", attaches a
vdd-pdphy-supply and adds a usb-c-connector child node.

Signed-off-by: Max Furman <taygoth@gmail.com>
---
 arch/arm64/boot/dts/qcom/pmi8998.dtsi | 33 +++++++++++++++++++++++++++
 1 file changed, 33 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/pmi8998.dtsi b/arch/arm64/boot/dts/qcom/pmi8998.dtsi
index 2ceee5ff8..caa9ab87b 100644
--- a/arch/arm64/boot/dts/qcom/pmi8998.dtsi
+++ b/arch/arm64/boot/dts/qcom/pmi8998.dtsi
@@ -30,6 +30,39 @@ pmi8998_charger: charger@1000 {
 			status = "disabled";
 		};
 
+		pmi8998_vbus: vbus-reg@1100 {
+			compatible = "qcom,pmi8998-vbus-reg",
+				     "qcom,pm8150b-vbus-reg";
+			reg = <0x1100>;
+			status = "disabled";
+		};
+
+		pmi8998_typec: typec@1300 {
+			compatible = "qcom,pmi8998-typec";
+			reg = <0x1300>, <0x1700>;
+
+			interrupts = <0x2 0x13 0x7 IRQ_TYPE_EDGE_BOTH>,
+				     <0x2 0x17 0x0 IRQ_TYPE_EDGE_RISING>,
+				     <0x2 0x17 0x1 IRQ_TYPE_EDGE_RISING>,
+				     <0x2 0x17 0x2 IRQ_TYPE_EDGE_RISING>,
+				     <0x2 0x17 0x3 IRQ_TYPE_EDGE_RISING>,
+				     <0x2 0x17 0x4 IRQ_TYPE_EDGE_RISING>,
+				     <0x2 0x17 0x5 IRQ_TYPE_EDGE_RISING>,
+				     <0x2 0x17 0x6 IRQ_TYPE_EDGE_RISING>;
+			interrupt-names = "type-c-change",
+					  "sig-tx",
+					  "sig-rx",
+					  "msg-tx",
+					  "msg-rx",
+					  "msg-tx-failed",
+					  "msg-tx-discarded",
+					  "msg-rx-discarded";
+
+			vdd-vbus-supply = <&pmi8998_vbus>;
+
+			status = "disabled";
+		};
+
 		pmi8998_gpios: gpio@c000 {
 			compatible = "qcom,pmi8998-gpio", "qcom,spmi-gpio";
 			reg = <0xc000>;
-- 
